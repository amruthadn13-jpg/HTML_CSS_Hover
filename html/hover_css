<!DOCTYPE html>
<html>
    <head>
        <title>library</title>
        <style>
            body{
                font-family: Arial;
                background-color:#f2f2f2;
            }

            header{
                background-color:darkgreen;
                color:gold;
                text-align:center;
                padding:20px;
            }

            .book-container{
                display:flex;
                justify-content:space-around;
                margin-top:20px;
            }

            .book{
                background-color:white;
                border:2px solid red;
                border-radius:10px;
                padding:20px;
                width:200px;
                text-align:center;
            }

            button{
                background-color:aquamarine;
                color:green;
                border:none;
                padding:10px;
                margin-top:10px;
                cursor:pointer;
            }

            button:hover{
                background-color:greenyellow;
            }

        </style>
    </head>

    <body>

        <header>
            <h1>Library Books</h1>
        </header>

        <div class="book-container">

        <div class="book">
        <h3>Atomic Habits</h3>
        <p>James Clear</p>
        <button>Borrow</button>
        </div>

        <div class="book">
        <h3>The Alchemist</h3>
        <p>Paulo Coelho</p>
        <button>Borrow</button>
        </div>

        <div class="book">
        <h3>Rich Dad Poor Dad</h3>
        <p>Robert Kiyosaki</p>
        <button>Borrow</button>
        </div>

        </div>

    </body>

</html>
